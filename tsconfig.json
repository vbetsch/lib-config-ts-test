{
    "extends": [
        "@vbetsch/lib-config-ts/tsconfig/base",
        "@vbetsch/lib-config-ts/tsconfig/strict",
        "@vbetsch/lib-config-ts/tsconfig/jsx"
    ],
    "compilerOptions": {
        "baseUrl": "./src",
        "noEmit": true,
        "paths": {
          "@src/*": ["src/*"],
        }
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "tests/**/*.ts",
        "tests/**/*.tsx"
    ]
}
